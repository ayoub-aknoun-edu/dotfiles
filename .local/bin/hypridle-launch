#!/usr/bin/env bash
# Start hypridle with the AC or battery config depending on current power source.
# Called by hypridle.service and restarted by hypridle-power-watcher when AC state changes.

if [[ "$(cat /sys/class/power_supply/AC/online 2>/dev/null)" == "1" ]]; then
    exec /usr/bin/hypridle -c ~/.config/hypr/hypridle-ac.conf
else
    exec /usr/bin/hypridle -c ~/.config/hypr/hypridle-battery.conf
fi
