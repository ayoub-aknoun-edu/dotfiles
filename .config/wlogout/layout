  {
    "label": "lock",
    "action": "pidof hyprlock >/dev/null 2>&1 || hyprlock -c ~/.config/hypr/hyprlock.conf",
    "text": "Lock",
    "keybind": "l"
  }
  {
    "label": "suspend",
    "action": "systemctl suspend",
    "text": "Sleep",
    "keybind": "z"
  }
  {
    "label": "logout",
    "action": "hyprctl dispatch exit",
    "text": "Logout",
    "keybind": "e"
  }
  {
    "label": "reboot",
    "action": "systemctl reboot",
    "text": "Reboot",
    "keybind": "r"
  }
  {
    "label": "shutdown",
    "action": "systemctl poweroff",
    "text": "Shutdown",
    "keybind": "s"
  }
