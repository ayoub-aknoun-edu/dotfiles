#!/usr/bin/env bash
set -euo pipefail

n="${1:?workspace number required}"

active="$(hyprctl -j activeworkspace 2>/dev/null | jq -r '.id // empty' 2>/dev/null || true)"
if [[ "$active" == "$n" ]]; then
    printf '{"text":"%s","class":"active"}\n' "$n"
    exit 0
fi

state="$(
    hyprctl -j workspaces 2>/dev/null |
        jq -r --argjson n "$n" '
            map(select(.id == $n and (.windows // 0) > 0)) |
            if length > 0 then "occupied" else "empty" end
        ' 2>/dev/null || true
)"

printf '{"text":"%s","class":"%s"}\n' "$n" "${state:-empty}"
